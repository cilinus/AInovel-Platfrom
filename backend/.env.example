# App
PORT=3101
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ainovel

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3101/api/auth/kakao/callback

# OAuth - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:3101/api/auth/naver/callback

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3101/api/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:3100

# Toss Payments
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# AI Service
AI_SERVICE_URL=http://localhost:8000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ainovel
S3_REGION=ap-northeast-2
