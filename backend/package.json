{
  "name": "ainovel-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0",
    "@nestjs/common": "^11.0",
    "@nestjs/config": "^4.0",
    "@nestjs/core": "^11.0",
    "@nestjs/jwt": "^11.0",
    "@nestjs/mongoose": "^11.0",
    "@nestjs/passport": "^11.0",
    "@nestjs/platform-express": "^11.0",
    "@nestjs/platform-socket.io": "^11.0",
    "@nestjs/swagger": "^11.0",
    "@nestjs/throttler": "^6.0",
    "@nestjs/websockets": "^11.0",
    "bcrypt": "^5.1",
    "bull": "^4.16",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "cookie-parser": "^1.4",
    "ioredis": "^5.4",
    "mongoose": "^8.10",
    "passport": "^0.7",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0",
    "passport-kakao": "^1.0",
    "passport-naver-v2": "^2.0.8",
    "rxjs": "^7.8",
    "socket.io": "^4.8",
    "winston": "^3.17",
    "winston-daily-rotate-file": "^5.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0",
    "@nestjs/schematics": "^11.0",
    "@nestjs/testing": "^11.0",
    "@swc/cli": "^0.6",
    "@swc/core": "^1.10",
    "@types/bcrypt": "^5.0",
    "@types/bull": "^4.10",
    "@types/cookie-parser": "^1.4",
    "@types/express": "^5.0",
    "@types/multer": "^1.4.13",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0",
    "jest": "^29.7",
    "prettier": "^3.5",
    "ts-jest": "^29.2",
    "typescript": "^5.7"
